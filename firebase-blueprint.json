{
  "entities": {
    "Link": {
      "title": "Link",
      "description": "A link displayed on the landing page",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The display title of the link" },
        "url": { "type": "string", "description": "The destination URL" },
        "image_url": { "type": "string", "description": "Optional image URL for the link" },
        "order_index": { "type": "number", "description": "Position in the list" }
      },
      "required": ["title", "url", "order_index"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global site settings",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "bio": { "type": "string" },
        "profile_image": { "type": "string" },
        "instagram_url": { "type": "string" },
        "linkedin_url": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/links/{linkId}": {
      "schema": "Link",
      "description": "Collection of links"
    },
    "/settings/config": {
      "schema": "Settings",
      "description": "Global configuration document"
    }
  }
}
